{
  "git": {
    "tagName": "v${version}",
    "requireCleanWorkingDir": false,
    "requireUpstream": false,
    "commit": false,
    "tag": false,
    "push": false
  },
  "npm": {
    "publish": false,
    "ignoreVersion": true
  },
  "github": {
    "release": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits"
    }
  }
}
