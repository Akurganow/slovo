# macOS / Xcode / SwiftPM
.DS_Store
.build/

# Node — dev-only release tooling (release-it). Only package.json and the
# lockfile are tracked; installed packages never are.
node_modules/
.swiftpm/
.codex/
.agentic/project-profile.md
*_handoff*
docs/agentic-workflow/
docs/superpowers/
DerivedData/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcuserstate

# ── Personalization data — NEVER commit ──────────────────────────────────────
# The dictionary DB is purely local user data. The app creates an empty DB from
# its schema on first run (create-or-get); an empty dictionary is a valid state.
# Pre-seeding is a local-only convenience and is NEVER shipped: seed files can
# contain personal vocabulary or other private terms. The public repository tracks
# only schema/migrations, no seed data and no user database.
# The repo tracks ONLY the schema/migrations (data/schema.sql), no seed, no DB.
# Globs (not exact names) so every future seed variant and DB sidecar is caught:
# data/seed.dev.sql, data/seed.2.sql, data/*.db-shm, and every DB sidecar stay
# uncommittable even across app renames.
data/*.db*
data/seed*.sql

# ── Key material / secrets — NEVER commit ────────────────────────────────────
# API keys, signing keys, and any credential bundles are user-owned secrets.
secrets/
*.key
*.pem
# Dotenv files, PKCS#12 / PKCS#8 signing keys, opaque token files, dropped
# credential JSON, and SSH private keys — none of these may ever be committed.
.env*
*.p12
*.p8
*.token
credentials*.json
id_rsa*
/.idea/

# Local scratch (user voice samples for on-device ASR checks) — never commit.
/tmp/
